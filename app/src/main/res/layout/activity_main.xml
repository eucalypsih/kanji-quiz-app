<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:padding="16dp"
    android:gravity="center"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <TextView
        android:id="@+id/kanjiText"
        android:textSize="32sp"
        android:text="Kanji"
        android:layout_marginBottom="16dp"/>

    <TextView
        android:id="@+id/questionText"
        android:textSize="24sp"
        android:layout_marginBottom="24dp"/>

    <Button android:id="@+id/btn1" android:layout_width="match_parent" android:layout_height="wrap_content"/>
    <Button android:id="@+id/btn2" android:layout_width="match_parent" android:layout_height="wrap_content"/>
    <Button android:id="@+id/btn3" android:layout_width="match_parent" android:layout_height="wrap_content"/>
    <Button android:id="@+id/btn4" android:layout_width="match_parent" android:layout_height="wrap_content"/>

    <TextView
        android:id="@+id/resultText"
        android:textSize="18sp"
        android:layout_marginTop="20dp"/>

</LinearLayout>

